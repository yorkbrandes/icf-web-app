# Database
DATABASE_URL=postgresql://user:password@localhost:5432/icf_db

# JWT
JWT_SECRET=your-very-long-random-secret-here-min-32-chars

# Boss Account (created on first start via instrumentation.ts)
BOSS_EMAIL=boss@example.com
BOSS_PASSWORD=SecureBossPassword123!

# App
APP_URL=http://localhost:3000
NODE_ENV=development

# Data Retention (days)
RETENTION_DAYS=365

# File Storage
UPLOAD_DIR=/app/uploads
