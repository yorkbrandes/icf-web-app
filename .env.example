# ── Datenbank ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://icf_user:changeme@postgres:5432/icf_db
POSTGRES_USER=icf_user
POSTGRES_PASSWORD=changeme
POSTGRES_DB=icf_db

# ── App ──────────────────────────────────────────────────────────────────────
APP_URL=https://ihre-domain.de
APP_DOMAIN=ihre-domain.de

# ── Auth ─────────────────────────────────────────────────────────────────────
# Mindestens 32 zufällige Zeichen, z.B.: openssl rand -hex 32
JWT_SECRET=aendern-sie-diesen-wert-mit-openssl-rand-hex-32

# ── Boss-Account ─────────────────────────────────────────────────────────────
BOSS_EMAIL=boss@ihre-domain.de
BOSS_PASSWORD=SicheresPasswort123!

# ── Retention ────────────────────────────────────────────────────────────────
RETENTION_DAYS=365

# ── Uploads ──────────────────────────────────────────────────────────────────
UPLOAD_DIR=/app/uploads

# ── Node ─────────────────────────────────────────────────────────────────────
NODE_ENV=production
